import React, { useState, useEffect } from 'react';
import { useAppContext } from '../../hooks/useAppContext';
import { v4 as uuidv4 } from 'uuid';
import { customToast as toast } from '../UI/toast';
import { Phone, CheckCircle2, Calendar, User, Clock, MapPin, ArrowLeft, Sun, Moon, Shield, Lock, Save, LogOut } from 'lucide-react';
import { LanguageToggle } from '../Shared/LanguageToggle';
import jalaali from 'jalaali-js';
import { useLocale } from '../../hooks/useLocale';
import Galaxy from '../Backgrounds/Galaxy';
import { motion, AnimatePresence } from 'motion/react';

const PERSIAN_MONTHS = ['فروردین', 'اردیبهشت', 'خرداد', 'تیر', 'مرداد', 'شهریور', 'مهر', 'آبان', 'آذر', 'دی', 'بهمن', 'اسفند'];
const ENGLISH_MONTHS = ['Farvardin', 'Ordibehesht', 'Khordad', 'Tir', 'Mordad', 'Shahrivar', 'Mehr', 'Aban', 'Azar', 'Dey', 'Bahman', 'Esfand'];

const getTodayJalali = () => {
    const today = new Date();
    const jDate = jalaali.toJalaali(today);
    return {
        jy: Math.floor(jDate.jy),
        jm: String(jDate.jm).padStart(2, '0'),
        jd: String(jDate.jd).padStart(2, '0'),
    }
}

export const ProfileSetup = () => {
  const { profile, setProfile, setCurrentView } = useAppContext();
  const { isFa, direction, tr } = useLocale();
  const todayVal = getTodayJalali();
  
  const [name, setName] = useState(profile?.name || '');
  const [selectedDay] = useState(todayVal.jd);
  const [selectedMonth] = useState(todayVal.jm);
  const [loginMode, setLoginMode] = useState<'expert' | 'admin'>('expert');
  const [adminPassword, setAdminPassword] = useState('');
  
  const initialShiftBase = profile?.shift === 'Morning' || profile?.shift === 'Evening' ? profile.shift : 
                           (profile?.shift ? 'Custom' : null);
                           
  const [selectedShiftBase, setSelectedShiftBase] = useState<'Morning' | 'Evening' | 'Custom' | null>(initialShiftBase as any);
  
  const [customShiftStart, setCustomShiftStart] = useState("");
  const [customShiftEnd, setCustomShiftEnd] = useState("");

  const [selectedBranch, setSelectedBranch] = useState<'Pardis' | 'Zargari' | null>(profile?.branch as any || null);

  useEffect(() => {
     if (profile?.shift && profile.shift !== 'Morning' && profile.shift !== 'Evening') {
        const parts = profile.shift.split(' to ');
        if (parts.length === 2) {
           setCustomShiftStart(parts[0]);
           setCustomShiftEnd(parts[1]);
        }
     }
  }, [profile]);

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();

    if (loginMode === 'admin') {
      if (!adminPassword) {
        toast.error(tr('لطفاً رمز عبور را وارد کنید', 'Please enter a password'));
        return;
      }
      if (adminPassword !== 'admin123') {
        toast.error(tr('رمز عبور نامعتبر است', 'Invalid password'));
        return;
      }
      setProfile({
        name: tr('مدیر سیستم', 'System Admin'),
        date: `1405/${selectedMonth}/${selectedDay}`,
        shift: 'Admin',
        branch: 'Admin',
        sessionId: profile?.sessionId || uuidv4(),
        role: 'admin'
      });
      setCurrentView('admin');
      toast.success(tr('به پنل مدیریت خوش آمدید', 'Welcome to the Admin panel'), { icon: '✓' });
      return;
    }

    if (!name.trim()) {
      toast.error(tr('لطفاً نام خود را وارد کنید', 'Please enter your name'));
      return;
    }
    if (!selectedShiftBase) {
      toast.error(tr('لطفاً شیفت کاری خود را انتخاب کنید', 'Please select your work shift'));
      return;
    }
    if (selectedShiftBase === 'Custom' && (!customShiftStart || !customShiftEnd)) {
      toast.error(tr('لطفاً زمان شروع و پایان شیفت سفارشی را مشخص کنید', 'Please set the custom shift start and end time'));
      return;
    }
    if (!selectedBranch) {
      toast.error(tr('لطفاً شعبه خود را انتخاب کنید', 'Please select your branch'));
      return;
    }
    
    const finalShift = selectedShiftBase === 'Custom' 
      ? `${customShiftStart} to ${customShiftEnd}`
      : selectedShiftBase;

    setProfile({
      name,
      date: `1405/${selectedMonth}/${selectedDay}`,
      shift: finalShift as any, 
      branch: selectedBranch as any,
      sessionId: profile?.sessionId || uuidv4(),
      role: 'expert'
    });
    setCurrentView('dashboard');
    toast.success(tr('به پنل تماس نوین‌تک خوش آمدید', 'Welcome to the NovinTech call panel'), { icon: '✓' });
  };

  const getShiftCardClass = (type: 'Morning' | 'Evening', isActive: boolean) => {
    const base = "relative overflow-hidden flex flex-col items-start justify-center p-4 rounded-2xl border transition-all duration-300 ease-out group cursor-pointer";
    if (!isActive) return `${base} bg-surface-hover border-border hover:border-border hover:bg-slate-300`;
    
    if (type === 'Morning') {
      return `${base} bg-gradient-to-br from-amber-500/20 to-orange-600/10 border-amber-400 ring-1 ring-amber-400/50`;
    } else {
      return `${base} bg-gradient-to-br from-indigo-500/20 to-blue-600/10 border-indigo-400 ring-1 ring-indigo-400/50`;
    }
  };

  const branchCardClass = (isActive: boolean) => `
    relative overflow-hidden w-full p-4 rounded-2xl border flex items-center justify-between transition-all duration-300 cursor-pointer
    ${isActive 
      ? 'bg-gradient-to-r from-emerald-500/20 to-emerald-600/10 border-emerald-400 ring-1 ring-emerald-400/50' 
      : 'bg-surface-hover border-border hover:border-border hover:bg-slate-300'
    }
  `;

  return (
    <div className="flex w-full min-h-[100vh] relative overflow-hidden text-primary" dir={direction}>
      {/* Luxurious Modern Background */}
      <div className="absolute inset-0 z-0 bg-bg-base overflow-hidden">
        {/* Animated Background Mesh/Blobs */}
        <div className="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-brand-300/10 blur-[120px] animate-[pulse_8s_ease-in-out_infinite]" />
        <div className="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-emerald-200/10 blur-[120px] animate-[pulse_10s_ease-in-out_infinite_reverse]" />
        <div className="absolute top-[20%] right-[10%] w-[30%] h-[30%] rounded-full bg-teal-200/10 blur-[100px] animate-[pulse_12s_ease-in-out_infinite]" />
        
        {/* Subtle grid pattern for texture */}
        <div className="absolute inset-0 bg-[linear-gradient(to_right,#e2e8f080_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f080_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
      </div>



      {/* Action Button (Login Toggle) */}
      <div className={`absolute top-6 z-50 px-6 ${direction === 'rtl' ? 'left-0' : 'right-0'}`}>
        <button 
          type="button"
          onClick={() => setLoginMode(loginMode === 'expert' ? 'admin' : 'expert')}
          className="flex items-center gap-2 bg-surface hover:bg-surface-hover text-primary border border-border rounded-full px-5 py-2 transition-all shadow-sm hover:shadow-md active:scale-95"
        >
          {loginMode === 'expert' ? (
            <><Shield size={16} className="text-indigo-600" /> <span className="text-sm font-medium">{tr('ورود مدیریت', 'Admin Login')}</span></>
          ) : (
            <><User size={16} className="text-brand-600" /> <span className="text-sm font-medium">{tr('ورود کارشناس', 'Expert Login')}</span></>
          )}
        </button>
      </div>

      <motion.div layout className={`w-full h-full flex flex-col ${loginMode === 'expert' ? 'lg:flex-row' : 'lg:flex-row-reverse'} relative z-20 min-h-[100vh] max-w-[1600px] mx-auto`}>
        
        {/* Branding side */}
        <motion.div layout className="w-full lg:w-5/12 p-8 md:p-12 lg:p-16 flex flex-col justify-center relative z-10">
          <motion.div 
            layout
            initial={{ opacity: 0, x: isFa ? 50 : -50 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ duration: 0.8, ease: "easeOut" }}
            className={`relative flex flex-col ${isFa ? 'text-right' : 'text-left'}`}
          >
            {/* Official Logo Area */}
            <div className="flex items-center gap-3 mb-8">
              <div className="relative flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700   ring-1 ring-white/50 overflow-hidden">
                <div className="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(255,255,255,0.2)_50%,transparent_75%)] bg-[length:250%_250%,100%_100%] animate-[shimmer_3s_infinite]" />
                <span className="text-3xl font-extrabold text-white tracking-tighter" style={{ fontFamily: 'system-ui' }}>N</span>
              </div>
              <div className="flex flex-col">
                <span className="text-2xl font-extrabold text-primary tracking-tight">{tr('نوین‌تک', 'NovinTech')}</span>
                <span className="text-sm font-normal text-brand-600 tracking-widest">{tr('NOVIN TECH', 'NOVIN TECH')}</span>
              </div>
            </div>
            
            <h1 className="text-4xl lg:text-5xl xl:text-6xl font-bold text-transparent bg-clip-text bg-gradient-to-b from-slate-900 to-slate-600 tracking-tight mb-6 leading-[1.15]">
              {tr('سامانه هوشمند', 'Smart Call')}<br />{tr('مدیریت تماس', 'Management System')}
            </h1>
            
            <p className="text-primary font-medium text-lg lg:text-xl leading-relaxed max-w-md">
              {tr('هسته مرکزی نوین‌تک', 'NovinTech Operations Hub')}<br />
              <span className="text-brand-600">{tr('یکپارچگی و سرعت در پشتیبانی مشتریان', 'Consistency and speed in customer support')}</span>
            </p>

            <div className="mt-12 flex items-center gap-4 bg-surface-hover border border-border rounded-2xl p-5 max-w-sm ">
              <div className="w-12 h-12 rounded-full bg-emerald-500/20 flex items-center justify-center border border-emerald-500/30">
                <div className="w-3 h-3 rounded-full bg-emerald-400 animate-[pulse_2s_ease-in-out_infinite] " />
              </div>
              <div>
                <h3 className="text-primary font-medium text-base mb-1">{tr('سیستم عملیاتی آماده', 'System ready')}</h3>
                <p className="text-sm text-secondary font-normal leading-relaxed">
                  {tr('اتصال ایمن به پایگاه داده مرکزی.', 'Secure connection to the central database.')}
                </p>
              </div>
            </div>
          </motion.div>
        </motion.div>

        {/* Form side */}
        <motion.div layout className="w-full lg:w-7/12 p-6 md:p-10 lg:p-16 flex flex-col justify-center items-center lg:items-start relative z-10">
           
           <motion.div 
              layout
              initial={{ opacity: 0, y: 30 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.6, delay: 0.2, ease: "easeOut" }}
              className="w-full max-w-[520px] rounded-3xl border border-border bg-surface p-8 md:p-10 shadow-sm relative overflow-hidden"
           >
              {/* Decorative top glow */}
              <div className="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-[1px] bg-gradient-to-r from-transparent via-brand-400 to-transparent opacity-50" />
              
               <div className="flex justify-between items-start mb-8">
                <div className={isFa ? 'text-right' : 'text-left'}>
                  <h2 className="text-3xl font-bold text-primary mb-2 tracking-tight">
                    {loginMode === 'expert' ? tr('ورود به پنل کارشناس', 'Expert Login') : tr('ورود به پنل مدیریت', 'Admin Login')}
                  </h2>
                </div>
                <div className="flex flex-col items-center justify-center bg-surface-hover border border-border rounded-xl px-4 py-2 text-primary" dir="ltr">
                  <Calendar size={16} className="mb-1 text-brand-400" />
                  <span className="text-xs font-medium">{selectedDay} {(isFa ? PERSIAN_MONTHS : ENGLISH_MONTHS)[parseInt(selectedMonth)-1]}</span>
                </div>
              </div>

              <div className="relative w-full">
                 <AnimatePresence mode="wait">
                   {loginMode === 'expert' ? (
                     <motion.form 
                       key="expert-form"
                       initial={{ opacity: 0, x: -20 }}
                       animate={{ opacity: 1, x: 0 }}
                       exit={{ opacity: 0, x: 20 }}
                       transition={{ duration: 0.3 }}
                       onSubmit={handleSubmit} 
                       className="space-y-8 w-full"
                     >
                     <div className="space-y-6">
                      
                       {/* Name Input */}
                       <div className="space-y-2 group">
                          <label className="flex items-center gap-2 text-sm font-medium text-primary px-1 transition-colors group-focus-within:text-brand-400">
                             <User size={16} />
                             <span>{tr('نام کارشناس', 'Expert Name')}</span>
                          </label>
                          <div className="relative">
                            <input
                              type="text"
                              required
                              value={name}
                              onChange={(e) => setName(e.target.value)}
                              placeholder={tr('نام و نام خانوادگی...', 'Enter full name...')}
                              className="w-full h-14 border border-border bg-surface-hover rounded-2xl px-4 text-base font-medium placeholder:text-[#9ca3af] focus:outline-none focus:border-brand-500 focus:bg-slate-300 focus:ring-4 focus:ring-brand-500/30 text-primary transition-all "
                            />
                          </div>
                       </div>

                      {/* Shift */}
                      <div className="space-y-3">
                         <label className="flex items-center gap-2 text-sm font-medium text-primary px-1">
                            <Clock size={16} />
                            <span>{tr('انتخاب شیفت', 'Select Shift')}</span>
                         </label>
                         <div className="grid grid-cols-2 gap-4">
                            <button type="button" onClick={() => setSelectedShiftBase('Morning')} className={getShiftCardClass('Morning', selectedShiftBase === 'Morning')}>
                                <div className="flex items-center justify-between w-full mb-1">
                                   <span className={`font-medium text-lg ${selectedShiftBase === 'Morning' ? 'text-amber-700' : 'text-primary'}`}>{tr('صبح', 'Morning')}</span>
                                   {selectedShiftBase === 'Morning' && <Sun size={18} className="text-amber-400" />}
                                </div>
                                <span className="text-sm font-medium text-muted" dir="ltr">08:00 - 14:30</span>
                            </button>
                            
                            <button type="button" onClick={() => setSelectedShiftBase('Evening')} className={getShiftCardClass('Evening', selectedShiftBase === 'Evening')}>
                                <div className="flex items-center justify-between w-full mb-1">
                                   <span className={`font-medium text-lg ${selectedShiftBase === 'Evening' ? 'text-indigo-700' : 'text-primary'}`}>{tr('عصر', 'Evening')}</span>
                                   {selectedShiftBase === 'Evening' && <Moon size={18} className="text-indigo-400" />}
                                </div>
                                <span className="text-sm font-medium text-muted" dir="ltr">14:30 - 21:00</span>
                            </button>
                         </div>
                      </div>

                       {/* Branch */}
                      <div className="space-y-3">
                         <label className="flex items-center gap-2 text-sm font-medium text-primary px-1">
                            <MapPin size={16} />
                            <span>{tr('موقعیت شعبه', 'Branch Location')}</span>
                         </label>
                         <div className="grid grid-cols-2 gap-4">
                            <button type="button" onClick={() => setSelectedBranch('Pardis')} className={branchCardClass(selectedBranch === 'Pardis')}>
                                <span className={`font-medium text-base ${selectedBranch === 'Pardis' ? 'text-emerald-700' : 'text-primary'}`}>{tr('پردیس', 'Pardis')}</span>
                                {selectedBranch === 'Pardis' && <CheckCircle2 size={18} className="text-emerald-400" />}
                            </button>
                            <button type="button" onClick={() => setSelectedBranch('Zargari')} className={branchCardClass(selectedBranch === 'Zargari')}>
                                <span className={`font-medium text-base ${selectedBranch === 'Zargari' ? 'text-emerald-700' : 'text-primary'}`}>{tr('زرگری', 'Zargari')}</span>
                                {selectedBranch === 'Zargari' && <CheckCircle2 size={18} className="text-emerald-400" />}
                            </button>
                         </div>
                      </div>

                     </div>

                     <div className="pt-6">
                       <button
                         type="submit"
                         className="group relative w-full h-14 flex items-center justify-center gap-3 font-bold text-white rounded-2xl text-lg bg-brand-600 hover:bg-brand-500 hover: transition-all duration-300 overflow-hidden"
                       >
                           <div className="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]" />
                           <span>{tr('ورود به پنل کارشناسی', 'Enter Expert Dashboard')}</span>
                           {isFa ? <ArrowLeft size={20} className="group-hover:-translate-x-1 transition-transform" /> : <ArrowLeft size={20} className="rotate-180 group-hover:translate-x-1 transition-transform" />}
                       </button>
                       <p className="text-center text-xs text-muted font-medium mt-6 tracking-wide">
                         {tr('« داده‌های شما به صورت امن در این دستگاه ذخیره می‌شود »', 'Your data is securely stored on this device.')}
                       </p>
                     </div>
                   </motion.form>
                   ) : (
                     <motion.form 
                       key="admin-form"
                       initial={{ opacity: 0, x: 20 }}
                       animate={{ opacity: 1, x: 0 }}
                       exit={{ opacity: 0, x: -20 }}
                       transition={{ duration: 0.3 }}
                       onSubmit={handleSubmit} 
                       className="space-y-8 w-full flex flex-col"
                     >
                     <div className="space-y-6 flex-1 flex flex-col justify-center mb-8">
                       <div className="space-y-2 group">
                          <label className="flex items-center gap-2 text-sm font-medium text-primary px-1 transition-colors group-focus-within:text-brand-400">
                             <Lock size={16} />
                             <span>{tr('رمز عبور مدیر', 'Admin Password')}</span>
                          </label>
                          <div className="relative">
                            <input
                              type="password"
                              required
                              value={adminPassword}
                              onChange={(e) => setAdminPassword(e.target.value)}
                              placeholder="••••••••"
                              className="w-full h-14 border border-border bg-surface-hover rounded-2xl px-4 text-center tracking-[0.3em] text-lg font-medium placeholder:text-[#9ca3af] focus:outline-none focus:border-brand-500 focus:bg-slate-300 focus:ring-4 focus:ring-brand-500/30 text-primary transition-all "
                              dir="ltr"
                            />
                          </div>
                       </div>
                       
                       <div className="flex items-center justify-center p-4 rounded-xl bg-amber-50 border border-amber-200 ">
                          <Shield size={24} className="text-amber-500 mr-3" />
                          <p className="text-sm text-amber-700 font-medium">
                            {tr('برای ورود به عنوان مدیر، رمز عبور پیش‌فرض admin123 را وارد کنید.', 'Enter admin123 to log in as admin.')}
                          </p>
                       </div>
                     </div>

                     <div className="pt-6">
                       <button
                         type="submit"
                         className="group relative w-full h-14 flex items-center justify-center gap-3 font-bold text-white rounded-2xl text-lg bg-indigo-600 hover:bg-indigo-500 hover: transition-all duration-300 overflow-hidden"
                       >
                           <div className="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]" />
                           <span>{tr('ورود به پنل مدیریت', 'Enter Admin Dashboard')}</span>
                           {isFa ? <ArrowLeft size={20} className="group-hover:-translate-x-1 transition-transform" /> : <ArrowLeft size={20} className="rotate-180 group-hover:translate-x-1 transition-transform" />}
                       </button>
                     </div>
                     </motion.form>
                   )}
                 </AnimatePresence>
              </div>
           </motion.div>
        </motion.div>
      </motion.div>
    </div>
  );
};
